{
  "name": "wayfinder",
  "version": "1.0.0",
  "private": true,
  "description": "Wayfinder — an agentic trip planner with season-aware destination selection and a guarded booking flow.",
  "workspaces": [
    "shared",
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm run dev -w server",
    "dev:web": "npm run dev -w web",
    "build": "npm run build -w web",
    "start": "npm run start -w server",
    "typecheck": "npm run typecheck -w server && npm run typecheck -w web",
    "check:budget": "npm run check:budget -w server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
