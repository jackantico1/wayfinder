# ── Wayfinder configuration ────────────────────────────────────────────────
# Copy to `.env`. Everything is OPTIONAL — the app is clone-and-runnable with
# zero keys (all providers fall back to deterministic mocks). Add a key to
# light up the real integration; the UI shows a MOCK / SANDBOX / LIVE badge
# per provider so the active mode is always visible.

# Anthropic API key — powers the season-aware planner + itinerary builder.
# Without it, a deterministic mock reasoner runs (badge: MOCK).
# `ant auth login` also works; the SDK resolves that profile automatically.
ANTHROPIC_API_KEY=

# Model used by the agent. Defaults to claude-opus-4-8.
ANTHROPIC_MODEL=claude-opus-4-8

# Duffel TEST-mode token (must start with `duffel_test_`). Powers real flight
# search + booking against Duffel's sandbox (Duffel Airways / IATA ZZ),
# paid with the unlimited Duffel Balance — no card, no real money.
# Without it, flights fall back to seeded mock offers (badge: MOCK).
DUFFEL_TEST_TOKEN=

# Server port.
PORT=4000
